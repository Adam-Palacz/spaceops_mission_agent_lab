# PS6.6 — GCP Secret Manager SecretStore stub (install ESO first).
# Wire Workload Identity on GKE before prod use (PS6.8).
apiVersion: external-secrets.io/v1beta1
kind: SecretStore
metadata:
  name: spaceops-secret-store
  namespace: spaceops-stage
spec:
  provider:
    gcpsm:
      projectID: REPLACE_GCP_PROJECT_ID
      auth:
        workloadIdentity:
          serviceAccountRef:
            name: spaceops-eso-reader
