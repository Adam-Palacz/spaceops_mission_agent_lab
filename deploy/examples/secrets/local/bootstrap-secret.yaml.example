# PS6.6 — apply manually for dev lab when secrets.create=false.
# Replace REPLACE_* placeholders, then:
#   kubectl apply -f deploy/examples/secrets/local/bootstrap-secret.yaml
# Or use: make k8s-secrets-bootstrap (reads env vars; does not print values).
apiVersion: v1
kind: Secret
metadata:
  name: spaceops-dev-secrets
  namespace: spaceops-dev
type: Opaque
stringData:
  postgres-password: "REPLACE_POSTGRES_PASSWORD"
  OPENAI_API_KEY: "REPLACE_OPENAI_API_KEY"
  # Optional keys — remove lines you do not use:
  # APPROVAL_API_KEY: "REPLACE_APPROVAL_API_KEY"
  # GITHUB_TOKEN: "REPLACE_GITHUB_TOKEN"
  # NGC_API_KEY: "REPLACE_NGC_API_KEY"
