# SpaceOps Mission Agent Lab — environment template
# Copy to .env and set values. Never commit .env (it is in .gitignore).

# Required for KB embedding and agent (OpenAI)
# OPENAI_API_KEY=<api_key>

# Optional: full Postgres URL (overrides POSTGRES_* below)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Postgres (defaults match infra/docker-compose.yml; required for KB/RAG, optional for API/agent-only runs)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=spaceops
# POSTGRES_PASSWORD=example_password
# POSTGRES_DB=spaceops

# OpenTelemetry exporter (S1.10): enable traces to local collector/Jaeger
# Example for local docker-compose collector (infra/docker-compose.yml, otel-collector on 4317):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# MCP servers (S1.7, S2.2) — optional overrides; defaults below
# TELEMETRY_MCP_URL=http://localhost:8001/mcp
# KB_MCP_URL=http://localhost:8002/mcp
# TICKET_MCP_URL=http://localhost:8003/mcp
# GITOPS_MCP_URL=http://localhost:8004/mcp

# GitOps (S2.2): optional; if set, create_pr will push branch and open PR via GitHub API
# GITHUB_TOKEN=<token_with_repo_scope>
# GITHUB_REPO=owner/repo   (or full URL: https://github.com/owner/repo)
# GITHUB_REPO_BASE_BRANCH=main

# Agent limits and timeouts (S1.12, NF6) — optional overrides
# Defaults are set in config.py; uncomment to override per environment.
# AGENT_RUN_TIMEOUT_SECONDS=120
# AGENT_LLM_CALL_TIMEOUT_SECONDS=30
# AGENT_TOKEN_BUDGET_PER_RUN=50000
# AGENT_MAX_LLM_CALLS_PER_RUN=10
