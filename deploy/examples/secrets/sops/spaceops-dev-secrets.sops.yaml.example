# PS6.6 — SOPS example (NOT encrypted). Encrypt before committing to a private repo:
#   sops --encrypt --age <age-pub> deploy/examples/secrets/sops/spaceops-dev-secrets.sops.yaml.example \
#     > deploy/secrets/spaceops-dev-secrets.sops.yaml
# Decrypt only on deploy hosts; never commit *.dec.yaml (see .gitignore).
apiVersion: v1
kind: Secret
metadata:
  name: spaceops-dev-secrets
  namespace: spaceops-dev
type: Opaque
stringData:
  postgres-password: "REPLACE_POSTGRES_PASSWORD"
  OPENAI_API_KEY: "REPLACE_OPENAI_API_KEY"
  APPROVAL_API_KEY: "REPLACE_APPROVAL_API_KEY"
  GITHUB_TOKEN: "REPLACE_GITHUB_TOKEN"
  NGC_API_KEY: "REPLACE_NGC_API_KEY"
