# SpaceOps Mission Agent Lab — environment template
# Copy to .env and set values. Never commit .env (it is in .gitignore).
# This file intentionally contains only placeholders/examples (no working secrets).

# Required for KB embedding and agent (OpenAI)
# OPENAI_API_KEY=<api_key>

# Agent LLM backend (PS5.1 — canonical):
# LLM_BACKEND=openai               # openai | cursor_sh | gpu
# LLM_PROVIDER=openai              # deprecated; used only when LLM_BACKEND unset
# OPENAI_BASE_URL=https://api.openai.com
# CURSOR_SH_API_KEY=<api_key>      # required when backend is cursor_sh
# CURSOR_SH_BASE_URL=https://api.cursor.sh
# GPU_LLM_BASE_URL=http://localhost:8005   # NIM when LLM_BACKEND=gpu (PS5.3)
# GPU_LLM_MODEL_ID=meta/llama-3.1-8b-instruct
# GPU_LLM_API_KEY=                 # optional bearer for NIM
# LLM_CHAT_COMPLETIONS_PATH=/v1/chat/completions

# Optional: full Postgres URL (overrides POSTGRES_* below)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Optional: migration-only override (Alembic uses this first when set)
# ALEMBIC_DATABASE_URL=postgresql://user:pass@host:5432/dbname

# NATS JetStream (PS3.2 — telemetry ingest per ADR 0002). Empty = legacy file ingest only.
# Docker Compose: set NATS_URL=nats://nats:4222 on api + run ``telemetry-persister`` service.
# NATS_URL=nats://localhost:4222
# JETSTREAM_STREAM_NAME=SPACEOPS_INGEST
# JETSTREAM_TELEMETRY_SUBJECT=ingest.telemetry
# JETSTREAM_PERSISTER_DURABLE=telemetry-persister
# JETSTREAM_PERSISTER_MAX_RETRIES=3
# JETSTREAM_PERSISTER_RETRY_BASE_SECONDS=2.0

# Postgres (required for docker compose postgres + KB/RAG; no default password in Compose)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=spaceops
# POSTGRES_PASSWORD=your_secret_here
# POSTGRES_DB=spaceops
# Example host DATABASE_URL (Compose overrides to postgres:5432 inside containers):
# DATABASE_URL=postgresql://spaceops:spaceops@localhost:5432/spaceops

# OpenTelemetry exporter (S1.10): enable traces to local collector/Jaeger
# Example for local docker-compose collector (infra/docker-compose.yml, otel-collector on 4317):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# MCP servers (S1.7, S2.2) — optional overrides; defaults below
# TELEMETRY_MCP_URL=http://localhost:8001/mcp
# KB_MCP_URL=http://localhost:8002/mcp
# TICKET_MCP_URL=http://localhost:8003/mcp
# GITOPS_MCP_URL=http://localhost:8004/mcp

# GitOps (S2.2): optional; if set, create_pr will push branch and open PR via GitHub API
# GITHUB_TOKEN=<token_with_repo_scope>
# GITHUB_REPO=owner/repo   (or full URL: https://github.com/owner/repo)
# GITHUB_REPO_BASE_BRANCH=main

# OPA (S2.4): policy for restricted actions (Act node)
# OPA_URL=http://localhost:8181/v1/data/agent/allow
# OPA_TIMEOUT_SECONDS=2

# S2.5 Approval API: auth and storage
# APPROVAL_API_KEY=<secret_key>   — required for GET/POST /approvals (header X-API-Key or Authorization: Bearer <key>)
# APPROVAL_STORE_PATH=            — optional; default data/approvals (directory for approval request JSON files)

# Agent limits and timeouts (S1.12, NF6) — optional overrides
# Defaults are set in config.py; uncomment to override per environment.
# AGENT_RUN_TIMEOUT_SECONDS=120
# AGENT_LLM_CALL_TIMEOUT_SECONDS=30
# AGENT_TOKEN_BUDGET_PER_RUN=50000
# AGENT_MAX_LLM_CALLS_PER_RUN=10
# AGENT_DURABLE_CHECKPOINT_ENABLED=false
# AGENT_DURABLE_CHECKPOINT_THREAD_PREFIX=incident

# S3.1 / P4.8 — shadow-testing (comma-separated candidate model ids; empty skips shadow CLI)
# AGENT_MODEL_ID=gpt-4o-mini
# AGENT_CANDIDATE_MODEL_IDS=gpt-4o
