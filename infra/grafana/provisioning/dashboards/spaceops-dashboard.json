{
  "id": null,
  "uid": "spaceops-main",
  "title": "SpaceOps Agent Metrics",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Agent runs (total)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(agent_runs_total)",
          "legendFormat": "all",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Runs by status",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum by (status) (agent_runs_total)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Run duration (seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(agent_run_duration_seconds_sum[1m]) / rate(agent_run_duration_seconds_count[1m])",
          "legendFormat": "p50",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Errors by type",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (type) (increase(agent_errors_total[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM/tool calls per run (histogram buckets)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum by (le) (rate(agent_tool_calls_per_run_bucket[5m]))",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    }
  ]
}

