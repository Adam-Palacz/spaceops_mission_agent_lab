# SpaceOps Mission Agent Lab — environment template
# Copy to .env and set values. Never commit .env (it is in .gitignore).
# This file intentionally contains only placeholders/examples (no working secrets).
#
# Environment model (PS6.1 / ADR 0005): local .env = dev semantics only.
# Stage/prod use Helm values overlays + secret refs — see docs/runbooks/environment_promotion.md

# Required for KB embedding and agent (OpenAI)
OPENAI_API_KEY=<api_key>

# Agent LLM backend (PS5.1 — canonical; required in all env templates):
LLM_BACKEND=openai               # openai | cursor_sh | gpu  (dev: openai default; gpu = local smoke only)
LLM_PROVIDER=openai              # DEPRECATED — do not use in K8s manifests; unset LLM_BACKEND instead
OPENAI_BASE_URL=https://api.openai.com
LLM_OPENAI_COST_PER_1K_TOKENS=0   # optional USD/1k tokens for estimated_cost_usd (PS5.2)
LLM_BUDGET_MODE=process           # process | postgres (postgres: shared UTC-day cap — PS7.6; stage/prod Helm)
LLM_DAILY_TOKEN_BUDGET=0          # 0 disables; process mode is per-process session guard
LLM_BUDGET_SOFT_WARNING_RATIO=0.8 # warning threshold before hard deny

# PS7.7 — multi-cloud burst policy (simulation; live cloud B deferred)
LLM_BURST_ENABLED=false
LLM_BURST_KILL_SWITCH=false
LLM_BURST_BACKEND=gpu
LLM_BURST_LATENCY_SLA_MS=2000
LLM_BURST_ROUTING_AUDIT=true
CURSOR_SH_API_KEY=<api_key>      # required when backend is cursor_sh
CURSOR_SH_BASE_URL=https://api.cursor.sh
# GPU / NVIDIA NIM (PS5.3 — optional; compose --profile gpu; requires NVIDIA GPU + NGC_API_KEY)
NGC_API_KEY=<ngc_api_key>
NIM_IMAGE=nvcr.io/nim/microsoft/phi-4-mini-instruct:1.12.0
NIM_RELAX_MEM_CONSTRAINTS=1      # local 8 GB smoke: bypass 95% free-memory admission check
NIM_NUM_KV_CACHE_SEQ_LENS=1      # minimal KV cache allocation with relaxed memory checks
NIM_MODEL_PROFILE=default
NIM_MODEL_NAME=hf://Qwen/Qwen2.5-0.5B-Instruct
NIM_SERVED_MODEL_NAME=qwen/qwen2.5-0.5b-instruct
GPU_IDLE_TTL_MINUTES=45          # PS5.7 host-side idle stop threshold for NIM
HF_TOKEN=
# Set HF_TOKEN only if Hugging Face download requires credentials.
GPU_LLM_BASE_URL=http://localhost:8005   # host-side gateway/smoke
GPU_LLM_CONTAINER_BASE_URL=http://nim-llm:8000  # optional API-container override
GPU_LLM_MODEL_ID=qwen/qwen2.5-0.5b-instruct
GPU_LLM_API_KEY=                 # optional bearer for NIM
GPU_ACTIVITY_FILE=./var/llm_last_gpu_call_at  # host; API maps its default to /app/var
LLM_GPU_HEALTHCHECK_TIMEOUT_SECONDS=3
LLM_GPU_CIRCUIT_BREAKER_FAILURES=3
LLM_GPU_CIRCUIT_BREAKER_RESET_SECONDS=60
LLM_CHAT_COMPLETIONS_PATH=/v1/chat/completions

# Optional: full Postgres URL (overrides POSTGRES_* below)
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Optional: migration-only override (Alembic uses this first when set)
ALEMBIC_DATABASE_URL=postgresql://user:pass@host:5432/dbname

# NATS JetStream (PS3.2 — telemetry ingest per ADR 0002). Empty = legacy file ingest only.
# Docker Compose: set NATS_URL=nats://nats:4222 on api + run ``telemetry-persister`` service.
NATS_URL=nats://localhost:4222
JETSTREAM_STREAM_NAME=SPACEOPS_INGEST
JETSTREAM_TELEMETRY_SUBJECT=ingest.telemetry
JETSTREAM_PERSISTER_DURABLE=telemetry-persister
JETSTREAM_PERSISTER_MAX_RETRIES=3
JETSTREAM_PERSISTER_RETRY_BASE_SECONDS=2.0

# Postgres (required for docker compose postgres + KB/RAG; no default password in Compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=spaceops
POSTGRES_PASSWORD=your_secret_here
POSTGRES_DB=spaceops
# Example host DATABASE_URL (Compose overrides to postgres:5432 inside containers):
DATABASE_URL=postgresql://spaceops:spaceops@localhost:5432/spaceops

# OpenTelemetry exporter (S1.10): enable traces to local collector/Jaeger
# Example for local docker-compose collector (infra/docker-compose.yml, otel-collector on 4317):
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
JAEGER_UI_URL=http://localhost:16686

# Audit log (S1.9): empty = repo data/audit.ndjson
AUDIT_LOG_PATH=

# MCP servers (S1.7, S2.2) — optional overrides; defaults below
TELEMETRY_MCP_URL=http://localhost:8001/mcp
KB_MCP_URL=http://localhost:8002/mcp
TICKET_MCP_URL=http://localhost:8003/mcp
GITOPS_MCP_URL=http://localhost:8004/mcp

# GitOps (S2.2): optional; if set, create_pr will push branch and open PR via GitHub API
GITHUB_TOKEN=<token_with_repo_scope>
GITHUB_REPO=owner/repo   (or full URL: https://github.com/owner/repo)
GITHUB_REPO_BASE_BRANCH=main

# OPA (S2.4): policy for restricted actions (Act node)
OPA_URL=http://localhost:8181/v1/data/agent/allow
OPA_TIMEOUT_SECONDS=2

# S2.5 Approval API: auth and storage
APPROVAL_API_KEY=<secret_key>   — required for GET/POST /approvals (header X-API-Key or Authorization: Bearer <key>)
APPROVAL_STORE_PATH=            — optional; default data/approvals (directory for approval request JSON files)

# Agent limits and timeouts (S1.12, NF6) — optional overrides
# Defaults are set in config.py; uncomment to override per environment.
AGENT_RUN_TIMEOUT_SECONDS=120
AGENT_LLM_CALL_TIMEOUT_SECONDS=30
AGENT_TOKEN_BUDGET_PER_RUN=50000
AGENT_MAX_LLM_CALLS_PER_RUN=10
AGENT_DURABLE_CHECKPOINT_ENABLED=false
AGENT_DURABLE_CHECKPOINT_THREAD_PREFIX=incident

# Agent context compaction (S3.3) — optional overrides
AGENT_MAX_HYPOTHESES=32
AGENT_MAX_CITATIONS=128
AGENT_HISTORY_COMPACTION_DEBUG=false

# HTTP/MCP retry and circuit breaker (S3.4) — optional overrides
HTTP_RESILIENCE_MAX_RETRIES=3
HTTP_RESILIENCE_BACKOFF_BASE_SECONDS=1.0
HTTP_RESILIENCE_CIRCUIT_BREAKER_FAILURES=5
HTTP_RESILIENCE_CIRCUIT_BREAKER_RESET_SECONDS=60.0

# S3.1 / P4.8 — shadow-testing (comma-separated candidate model ids; empty skips shadow CLI)
AGENT_MODEL_ID=gpt-4o-mini
AGENT_CANDIDATE_MODEL_IDS=gpt-4o

# P4.4 / NF5 — KB reranker (optional)
KB_RERANKER_ENABLED=false
KB_RERANKER_MODE=lexical       # lexical | llm
KB_RERANKER_RETRIEVE_K=10
KB_RERANKER_LLM_MODEL=gpt-4o-mini

# PS6.3 — local kind + Helm helper overrides (optional)
K8S_CLUSTER_NAME=spaceops-dev
K8S_HELM_RELEASE=spaceops
K8S_NAMESPACE=spaceops-dev
K8S_API_LOCAL_PORT=18000
K8S_POSTGRES_PASSWORD=spaceops
K8S_SKIP_BUILD=0
K8S_IMAGE_API=spaceops-api:local
K8S_IMAGE_MCP=spaceops-mcp:local

# Next.js operator UI (optional; typically use apps/ui/.env.local)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APPROVAL_API_KEY=
NEXT_PUBLIC_JAEGER_UI_URL=http://localhost:16686
