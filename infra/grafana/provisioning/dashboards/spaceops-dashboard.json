{
  "id": null,
  "uid": "spaceops-main",
  "title": "SpaceOps Agent Metrics",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Agent runs (total)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(agent_runs_total)",
          "legendFormat": "all",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Runs by status",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum by (status) (agent_runs_total)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Run duration (seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(agent_run_duration_seconds_sum[1m]) / rate(agent_run_duration_seconds_count[1m])",
          "legendFormat": "p50",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Errors by type",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (type) (increase(agent_errors_total[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM/tool calls per run (histogram buckets)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum by (le) (rate(agent_tool_calls_per_run_bucket[5m]))",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Escalation rate (PS4.6)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "sum(rate(agent_escalations_total[5m])) / sum(rate(agent_behavior_runs_total[5m]))",
          "legendFormat": "escalation_rate",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Escalations by reason (PS4.6)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "targets": [
        {
          "expr": "sum by (reason) (rate(agent_escalations_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Evidence coverage — policy OK share (PS4.6)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "targets": [
        {
          "expr": "sum(rate(agent_evidence_coverage_total{policy_status=\"ok\"}[5m])) / sum(rate(agent_evidence_coverage_total[5m]))",
          "legendFormat": "ok_share",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Stage duration p95 (PS4.6)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 52 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (stage, le) (rate(agent_stage_duration_seconds_bucket[5m])))",
          "legendFormat": "{{stage}} p95",
          "refId": "A"
        }
      ]
    }
  ]
}

