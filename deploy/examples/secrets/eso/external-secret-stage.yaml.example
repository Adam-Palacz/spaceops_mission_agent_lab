# PS6.6 — ExternalSecret for stage (requires ESO + SecretStore installed).
# Store paths match ADR 0007: spaceops-stage/<key-name>
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: spaceops-stage-secrets
  namespace: spaceops-stage
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: spaceops-secret-store
    kind: SecretStore
  target:
    name: spaceops-stage-secrets
    creationPolicy: Owner
  data:
    - secretKey: postgres-password
      remoteRef:
        key: spaceops-stage/postgres-password
    - secretKey: OPENAI_API_KEY
      remoteRef:
        key: spaceops-stage/openai-api-key
    - secretKey: APPROVAL_API_KEY
      remoteRef:
        key: spaceops-stage/approval-api-key
    - secretKey: GITHUB_TOKEN
      remoteRef:
        key: spaceops-stage/github-token
    - secretKey: NGC_API_KEY
      remoteRef:
        key: spaceops-stage/ngc-api-key
